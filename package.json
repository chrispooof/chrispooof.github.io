{
  "name": "website",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "deploy": "gh-pages -b master -d dist",
    "test": "vitest",
    "test:run": "vitest run",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "gh-pages": "^5.0.0",
    "tailwindcss": "^4.2.1",
    "three": "^0.183.2"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": "prettier --write"
  },
  "devDependencies": {
    "@types/three": "^0.183.1",
    "husky": "^9.1.7",
    "jsdom": "^29.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "typescript": "^5.9.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.0"
  }
}
